{
  "name": "Huzaifa_Autos_App",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:desktop": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "dev:frontend": "next dev",
    "dev:backend": "echo \"No local backend found in this repo. Configure NEXT_PUBLIC_API_BASE_URL or restore backend/index.js.\"",
    "build": "next build",
    "build:web": "next build",
    "prepare:desktop": "node electron/prepare-desktop.cjs",
    "build:desktop": "npm run build:web && npm run prepare:desktop && electron-builder",
    "start": "next start",
    "start:desktop": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "lint": "eslint"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fs-extra": "^11.3.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.561.0",
    "mongoose": "^8.19.4",
    "morgan": "^1.10.1",
    "next": "16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.6.0",
    "streamifier": "^0.1.1",
    "xlsx": "^0.18.5",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "enhanced-resolve": "^5.20.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "nodemon": "^3.1.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.Huzaifa_Autos_App.desktop",
    "productName": "Huzaifa_Autoes_App",
    "icon": "public/impage/app_icon.ico",
    "asar": false,
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      ".env",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/impage/app_icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
